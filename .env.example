# ============================================================
# Fazz PitchSide Hub — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Generate a new key with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-with-a-strong-random-key

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hosts
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Google Gemini API key (for AI bio generator)
GEMINI_API_KEY=your-gemini-api-key-here
